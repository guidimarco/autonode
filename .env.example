# User & GIT
CURRENT_UID=1000
CURRENT_GID=1000
DOCKER_GID=999

GIT_AUTHOR_NAME=Nome Cognome
GIT_AUTHOR_EMAIL=nome.cognome@example.com

# Autonode
HOST_PROJECTS_ROOT=/percorso/assoluto/al/parent/della/repo
HOST_DATA_ROOT=/percorso/assoluto/al/parent/della/repo/autonode_data
AUTONODE_DB_PATH=/data/autonode.db
DATA_ROOT=/data

AUTONODE_PORT=8000
AUTONODE_HOST=0.0.0.0
AUTONODE_API_KEY=api-key-secret
AUTONODE_LOG_LEVEL=INFO

# OpenRouter (LLM) — required for agent factory and tools
OPEN_ROUTER_API_KEY=sk-or-...

# LangSmith (Logs)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=autonode
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# ^ ^ ^ Self-hosted endpoint

# ngrok
NGROK_AUTHTOKEN=ngrok-auth-token