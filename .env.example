# User & GIT
CURRENT_UID=1000
CURRENT_GID=1000
DOCKER_GID=999
GIT_AUTHOR_NAME=Nome Cognome
GIT_AUTHOR_EMAIL=nome.cognome@example.com

# ngrok
NGROK_AUTHTOKEN=ngrok-auth-token

# Autonode
AUTONODE_PORT=8000
AUTONODE_HOST=0.0.0.0
AUTONODE_API_KEY=api-key-secret
AUTONODE_LOG_LEVEL=INFO
AUTONODE_DB_PATH=/app/.autonode/db/autonode.db

# OpenRouter (LLM) — required for agent factory and tools
OPEN_ROUTER_API_KEY=sk-or-...

# LangSmith (Logs)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=autonode
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# ^ ^ ^ Self-hosted endpoint

# MCP server
AUTONODE_MCP_LOG_LEVEL=INFO