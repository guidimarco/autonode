{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Autonode: Fix",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/fix",
      "problemMatcher": [],
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "Autonode: Lint",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/lint",
      "problemMatcher": [],
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Autonode: Unit Tests",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/pytest",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Autonode: Validate All",
      "dependsOrder": "sequence",
      "dependsOn": ["Autonode: Fix", "Autonode: Lint", "Autonode: Unit Tests"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
